# HTTP/WS listen port (Render injects this)
PORT=3000

# Pino log level (debug/info/warn/error)
LOG_LEVEL=info

# How often to ping clients (ms)
HEARTBEAT_INTERVAL_MS=30000

# Grace period before a non-ponging client is dropped (ms)
HEARTBEAT_TIMEOUT_MS=10000

# Max inbound WS frame size (bytes)
MAX_PAYLOAD_BYTES=4096

# Upper bound for room id total length
MAX_ROOM_ID_LENGTH=128

# Upper bound for display name length
MAX_NAME_LENGTH=32

# Upper bound for vote value length
MAX_VOTE_LENGTH=64

# Max wait for graceful shutdown before forced exit (ms)
SHUTDOWN_GRACE_MS=20000

# Max concurrent users in a room
MAX_ROOM_USERS=50

# Rate-limit window length (ms)
MESSAGE_RATE_WINDOW_MS=1000

# Max inbound messages per window before rate-limit
MESSAGE_RATE_BURST=20